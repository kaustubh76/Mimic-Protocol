# envio-pm-template-v1 — environment variables
#
# Copy this file to `.env` and fill in the RPC URLs.

# Polygon mainnet RPC (chain 137) — Polymarket's home chain.
ENVIO_POLYGON_RPC_URL=https://polygon-bor.publicnode.com

# Base mainnet RPC (chain 8453) — Limitless's home chain.
ENVIO_BASE_RPC_URL=https://base.publicnode.com
