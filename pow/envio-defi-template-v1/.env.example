# envio-defi-template-v1 — environment variables
#
# Copy this file to `.env` (gitignored) and fill in the RPC URLs.
# RPC URLs are read in src/Constants.ts via process.env.{rpcEnvVar}.

# Optimism mainnet RPC (chain 10) — used for Velodrome V2.
# Alchemy / QuickNode / public Optimism endpoints all work.
ENVIO_OPTIMISM_RPC_URL=https://optimism.publicnode.com

# Base mainnet RPC (chain 8453) — used for Aerodrome.
ENVIO_BASE_RPC_URL=https://base.publicnode.com
