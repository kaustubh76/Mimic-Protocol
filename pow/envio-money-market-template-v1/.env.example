# envio-money-market-template-v1 — environment variables
#
# Copy this file to `.env` and fill in the RPC URLs.

# Polygon — Aave V3's largest L2 deployment
ENVIO_POLYGON_RPC_URL=https://polygon-bor.publicnode.com

# Arbitrum One — Aave V3
ENVIO_ARBITRUM_RPC_URL=https://arbitrum-one.publicnode.com

# Base — Aave V3
ENVIO_BASE_RPC_URL=https://base.publicnode.com
