// SPDX-License-Identifier: MIT
pragma solidity ^0.8.20;

import "forge-std/Test.sol";
import "../contracts/BehavioralNFT.sol";
import "../contracts/DelegationRouter.sol";
import "../contracts/PatternDetector.sol";
import "../contracts/ExecutionEngine.sol";

/**
 * @title EndToEndTest
 * @notice Complete end-to-end test of Mirror Protocol smart contracts
 * @dev Tests: Pattern Minting -> Delegation -> Execution
 */
contract EndToEndTest is Test {
    BehavioralNFT public nft;
    DelegationRouter public router;
    PatternDetector public detector;
    ExecutionEngine public engine;

    address public deployer;
    address public trader1;
    address public trader2;

    // Events to test
    event PatternMinted(uint256 indexed tokenId, address indexed creator, string patternType);
    event DelegationCreated(uint256 indexed delegationId, address indexed delegator, uint256 indexed patternTokenId);
    event TradeExecuted(uint256 indexed delegationId, address indexed executor, uint256 volume);

    function setUp() public {
        deployer = address(this);
        trader1 = makeAddr("trader1");
        trader2 = makeAddr("trader2");

        // Deploy all contracts
        nft = new BehavioralNFT();
        detector = new PatternDetector(address(nft));
        router = new DelegationRouter(address(nft));
        engine = new ExecutionEngine(address(router), address(nft));

        // Setup: Grant minter role to detector
        nft.grantMinterRole(address(detector));

        // Setup: Set ExecutionEngine in DelegationRouter
        router.setExecutionEngine(address(engine));

        // Fund test accounts
        vm.deal(trader1, 100 ether);
        vm.deal(trader2, 100 ether);
    }

    function testCompleteFlow() public {
        console.log("=================================================");
        console.log("END-TO-END TEST: Complete Mirror Protocol Flow");
        console.log("=================================================");

        // ============================
        // STEP 1: MINT A PATTERN
        // ============================
        console.log("\n1. MINTING PATTERN");
        console.log("-------------------");

        vm.startPrank(trader1);

        // Create transaction data for pattern
        PatternDetector.Transaction[] memory txs = new PatternDetector.Transaction[](5);

        // Create winning trades (80% win rate)
        for (uint i = 0; i < 4; i++) {
            txs[i] = PatternDetector.Transaction({
                tokenIn: address(uint160(0x1111111111111111111111111111111111111111 + i)),
                tokenOut: address(uint160(0x2222222222222222222222222222222222222222 + i)),
                amountIn: 1 ether,
                amountOut: 1.1 ether, // 10% profit
                timestamp: block.timestamp - (5 - i) * 1 days,
                isProfit: true
            });
        }

        // One losing trade
        txs[4] = PatternDetector.Transaction({
            tokenIn: address(0x5555555555555555555555555555555555555555),
            tokenOut: address(0x6666666666666666666666666666666666666666),
            amountIn: 1 ether,
            amountOut: 0.95 ether, // 5% loss
            timestamp: block.timestamp - 1 days,
            isProfit: false
        });

        // Submit pattern - should mint NFT
        vm.expectEmit(true, true, false, true);
        emit PatternMinted(1, trader1, "TestStrategy");

        detector.submitPattern(txs, "TestStrategy");

        vm.stopPrank();

        // Verify pattern was minted
        assertEq(nft.totalPatterns(), 1, "Pattern should be minted");
        assertEq(nft.ownerOf(1), trader1, "Trader1 should own the pattern NFT");

        console.log("  Pattern minted: Token ID 1");
        console.log("  Owner:", trader1);
        console.log("  Pattern Type: TestStrategy");

        // ============================
        // STEP 2: CREATE DELEGATION
        // ============================
        console.log("\n2. CREATING DELEGATION");
        console.log("----------------------");

        vm.startPrank(trader2);

        // Trader2 delegates to trader1's pattern
        uint256 percentageAllocation = 2500; // 25%

        vm.expectEmit(true, true, true, false);
        emit DelegationCreated(1, trader2, 1);

        router.createSimpleDelegation(
            1, // patternTokenId
            percentageAllocation
        );

        vm.stopPrank();

        // Verify delegation was created
        uint256[] memory trader2Delegations = router.getDelegatorDelegations(trader2);
        assertEq(trader2Delegations.length, 1, "Should have 1 delegation");
        assertEq(trader2Delegations[0], 1, "Delegation ID should be 1");

        // Check delegation details
        (
            address delegator,
            uint256 patternTokenId,
            uint256 allocation,
            ,,,,,
            bool isActive,
        ) = router.delegations(1);

        assertEq(delegator, trader2, "Delegator should be trader2");
        assertEq(patternTokenId, 1, "Should delegate to pattern 1");
        assertEq(allocation, 2500, "Allocation should be 25%");
        assertTrue(isActive, "Delegation should be active");

        console.log("  Delegation created: ID 1");
        console.log("  Delegator:", trader2);
        console.log("  Pattern Token ID: 1");
        console.log("  Allocation: 25%");

        // ============================
        // STEP 3: EXECUTE TRADE
        // ============================
        console.log("\n3. EXECUTING TRADE VIA DELEGATION");
        console.log("-----------------------------------");

        // Pattern owner (trader1) executes a trade on behalf of delegator (trader2)
        vm.startPrank(trader1);

        address tokenIn = address(0xAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA);
        address tokenOut = address(0xBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB);
        uint256 amountIn = 1 ether;
        uint256 amountOut = 1.15 ether; // 15% profit

        // Execute trade through ExecutionEngine
        vm.expectEmit(true, true, false, true);
        emit TradeExecuted(1, trader1, amountIn);

        engine.executeTrade(
            1, // delegationId
            tokenIn,
            tokenOut,
            amountIn,
            amountOut
        );

        vm.stopPrank();

        console.log("  Trade executed successfully");
        console.log("  Delegation ID: 1");
        console.log("  Token In:", tokenIn);
        console.log("  Token Out:", tokenOut);
        console.log("  Amount In: 1 ETH");
        console.log("  Amount Out: 1.15 ETH (15% profit)");

        // ============================
        // STEP 4: VERIFY STATE CHANGES
        // ============================
        console.log("\n4. VERIFYING FINAL STATE");
        console.log("-------------------------");

        // Check pattern performance was updated
        (
            string memory patternType,
            address creator,
            ,
            uint256 createdAt,
            uint256 winRate,
            uint256 totalVolume,
            uint256 roi,
            bool patternActive,
        ) = nft.patterns(1);

        console.log("  Pattern Performance:");
        console.log("    Type:", patternType);
        console.log("    Creator:", creator);
        console.log("    Win Rate:", winRate, "basis points");
        console.log("    Total Volume:", totalVolume);
        console.log("    ROI:", roi, "basis points");
        console.log("    Is Active:", patternActive);

        assertTrue(patternActive, "Pattern should still be active");
        assertGt(totalVolume, 0, "Should have volume from trades");

        // Check delegation is still active
        (,,,,,,,, bool delegationStillActive,) = router.delegations(1);
        assertTrue(delegationStillActive, "Delegation should still be active");

        console.log("\n  Delegation Status:");
        console.log("    Still Active:", delegationStillActive);

        // ============================
        // STEP 5: TEST REVOCATION
        // ============================
        console.log("\n5. TESTING DELEGATION REVOCATION");
        console.log("---------------------------------");

        vm.prank(trader2);
        router.revokeDelegation(1);

        (,,,,,,,, bool isActiveAfterRevoke,) = router.delegations(1);
        assertFalse(isActiveAfterRevoke, "Delegation should be revoked");

        console.log("  Delegation revoked successfully");
        console.log("  Is Active:", isActiveAfterRevoke);

        console.log("\n=================================================");
        console.log("END-TO-END TEST PASSED!");
        console.log("=================================================");
        console.log("\nAll contract interactions verified:");
        console.log("  [OK] Pattern Minting (PatternDetector -> BehavioralNFT)");
        console.log("  [OK] Delegation Creation (DelegationRouter)");
        console.log("  [OK] Trade Execution (ExecutionEngine -> DelegationRouter)");
        console.log("  [OK] Performance Updates (ExecutionEngine -> BehavioralNFT)");
        console.log("  [OK] Delegation Revocation (DelegationRouter)");
    }

    function testExecutionEnginePermissions() public {
        console.log("\n=== Testing ExecutionEngine Permissions ===");

        // Setup: Mint pattern and create delegation
        vm.startPrank(trader1);
        PatternDetector.Transaction[] memory txs = createTestTransactions();
        detector.submitPattern(txs, "TestPattern");
        vm.stopPrank();

        vm.prank(trader2);
        router.createSimpleDelegation(1, 2500);

        // Test: Only pattern owner can execute trades
        vm.prank(trader2);
        vm.expectRevert(); // Should revert - trader2 is not pattern owner
        engine.executeTrade(
            1,
            address(0x1111),
            address(0x2222),
            1 ether,
            1.1 ether
        );

        // Pattern owner should succeed
        vm.prank(trader1);
        engine.executeTrade(
            1,
            address(0x1111),
            address(0x2222),
            1 ether,
            1.1 ether
        );

        console.log("  [OK] Only pattern owner can execute trades");
    }

    function testMultipleDelegations() public {
        console.log("\n=== Testing Multiple Delegations ===");

        // Setup: Mint pattern
        vm.startPrank(trader1);
        PatternDetector.Transaction[] memory txs = createTestTransactions();
        detector.submitPattern(txs, "PopularPattern");
        vm.stopPrank();

        // Create multiple delegations
        address trader3 = makeAddr("trader3");
        address trader4 = makeAddr("trader4");

        vm.prank(trader2);
        router.createSimpleDelegation(1, 2500); // 25%

        vm.prank(trader3);
        router.createSimpleDelegation(1, 5000); // 50%

        vm.prank(trader4);
        router.createSimpleDelegation(1, 2500); // 25%

        // Verify all delegations
        assertEq(router.getDelegatorDelegations(trader2).length, 1);
        assertEq(router.getDelegatorDelegations(trader3).length, 1);
        assertEq(router.getDelegatorDelegations(trader4).length, 1);

        console.log("  [OK] Multiple users can delegate to same pattern");
        console.log("  Total Delegations: 3");
    }

    // Helper function
    function createTestTransactions() internal view returns (PatternDetector.Transaction[] memory) {
        PatternDetector.Transaction[] memory txs = new PatternDetector.Transaction[](5);
        for (uint i = 0; i < 5; i++) {
            txs[i] = PatternDetector.Transaction({
                tokenIn: address(uint160(0x1000 + i)),
                tokenOut: address(uint160(0x2000 + i)),
                amountIn: 1 ether,
                amountOut: 1.1 ether,
                timestamp: block.timestamp - (5 - i) * 1 days,
                isProfit: true
            });
        }
        return txs;
    }
}
