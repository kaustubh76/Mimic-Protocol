{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@handlers/*": ["./handlers/*"],
      "@utils/*": ["./utils/*"],
      "@queries/*": ["./queries/*"],
      "@generated/*": ["./generated/*"]
    }
  },
  "include": [
    "src/**/*",
    "handlers/**/*",
    "utils/**/*",
    "queries/**/*",
    "generated/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ]
}
