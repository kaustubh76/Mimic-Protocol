# Network Configuration
MONAD_RPC_URL=https://testnet.monad.xyz/rpc
MONAD_CHAIN_ID=10143

# Private Keys (DO NOT COMMIT ACTUAL KEYS)
DEPLOYER_PRIVATE_KEY=your_private_key_here
OWNER_PRIVATE_KEY=your_owner_private_key_here

# Envio Configuration
ENVIO_API_KEY=your_envio_api_key_here
HYPERSYNC_ENDPOINT=https://hypersync.envio.dev
ENVIO_WEBHOOK_SECRET=your_webhook_secret_here

# MetaMask Configuration
METAMASK_PROJECT_ID=your_metamask_project_id_here
DELEGATION_FRAMEWORK_URL=https://delegation.metamask.io

# Contract Addresses (Fill after deployment)
BEHAVIORAL_NFT_ADDRESS=
DELEGATION_ROUTER_ADDRESS=
PATTERN_REGISTRY_ADDRESS=
EXECUTION_ENGINE_ADDRESS=

# API Configuration
PORT=3000
WS_PORT=8080
NODE_ENV=development

# Frontend Configuration
NEXT_PUBLIC_MONAD_RPC=https://testnet.monad.xyz/rpc
NEXT_PUBLIC_CHAIN_ID=10143

# Performance Monitoring
ENABLE_METRICS=true
METRICS_INTERVAL=5000

# Security
MAX_GAS_PRICE=100
SPENDING_LIMIT_PER_DELEGATION=1000
EMERGENCY_STOP_ENABLED=true
