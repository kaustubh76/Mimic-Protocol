{
  "name": "mirror-protocol",
  "version": "1.0.0",
  "description": "Behavioral Liquidity Infrastructure Powered by Envio HyperCore",
  "main": "src/index.js",
  "scripts": {
    "dev": "cd src/envio && envio dev",
    "compile": "forge build",
    "test": "forge test",
    "test:verbose": "forge test -vvv",
    "deploy": "forge script script/DeployAll.s.sol:DeployAll --rpc-url monad --broadcast",
    "deploy:dry": "forge script script/DeployAll.s.sol:DeployAll --rpc-url monad",
    "post-deploy": "bash scripts/update-addresses.sh",
    "envio:codegen": "cd src/envio && envio codegen",
    "envio:dev": "cd src/envio && envio dev",
    "frontend": "cd src/frontend && npm run dev",
    "frontend:build": "cd src/frontend && npm run build",
    "bot": "node executor-bot/bot.mjs",
    "lint": "forge fmt --check",
    "format": "forge fmt"
  },
  "keywords": [
    "envio",
    "metamask",
    "monad",
    "delegations",
    "behavioral-liquidity",
    "defi",
    "nft"
  ],
  "author": "Mirror Protocol Team",
  "license": "MIT",
  "dependencies": {
    "envio": "2.32.6",
    "@envio-dev/hypersync-client": "^0.5.0",
"@metamask/sdk": "^0.26.0",
    "@openzeppelin/contracts": "^5.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.10",
    "eslint": "^8.54.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.1.0",
    "prettier-plugin-solidity": "^1.2.0",
    "solidity-coverage": "^0.8.5",
    "typechain": "^8.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
