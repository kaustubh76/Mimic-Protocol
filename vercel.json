{
  "buildCommand": "cd src/frontend && npx vite build",
  "outputDirectory": "src/frontend/dist",
  "installCommand": "npm install --legacy-peer-deps --prefix src/frontend",
  "rewrites": [
    {
      "source": "/api/envio/:path*",
      "destination": "https://indexer.dev.hyperindex.xyz/b383f5b/v1/:path*"
    }
  ]
}
